rules_version = '2';

// All lead data is accessed exclusively through the server-side API (Firebase
// Admin SDK), which bypasses these rules. Direct client access is denied, so
// no credentials or collection data are ever exposed to the browser.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
