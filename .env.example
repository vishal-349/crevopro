# ----------------------------------------------------------------------------
# CrevoPro environment variables
# Copy to `.env` for local dev (used by `vercel dev`) and set the same values
# in the Vercel project settings for production.
# ----------------------------------------------------------------------------

# --- Firebase (REQUIRED for lead capture) -----------------------------------
# From a Firebase service-account JSON (Project settings → Service accounts).
# Keep FIREBASE_PRIVATE_KEY in double quotes; escaped \n newlines are handled.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""

# --- Admin panel (REQUIRED for /admin) --------------------------------------
ADMIN_PASSWORD=
# Any long random string used to sign admin session cookies, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Email notifications (OPTIONAL) -----------------------------------------
# If unset, leads are still saved — email is simply skipped.
RESEND_API_KEY=
EMAIL_FROM="CrevoPro <onboarding@resend.dev>"
# Notification recipient(s); comma-separated for multiple admins.
ADMIN_EMAIL=infocrevopro@gmail.com

# --- WhatsApp notifications (OPTIONAL, dormant unless all set) ---------------
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TO=

# --- CRM webhook (OPTIONAL, dormant unless URL set) -------------------------
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=
